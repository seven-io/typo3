{
    "name": "seven.io/typo3",
    "type": "typo3-cms-extension",
    "description": "Send SMS & voice messages via seven.io.",
    "license": "MIT",
    "replace": {
        "typo3-ter/seventypo3": "self.version"
    },
    "authors": [
        {
            "name": "seven communications GmbH & Co. KG",
            "role": "Developer",
            "email": "a.matthies@seven.io",
            "homepage": "https://www.seven.io"
        }
    ],
    "keywords": [
        "typo3",
        "sms",
        "seven",
        "voice",
        "lookup"
    ],
    "require": {
        "php": "^8.2",
        "seven.io/api": "^8.1",
        "typo3/cms-backend": "^12.4 || ^13.4",
        "typo3/cms-core": "^12.4 || ^13.4",
        "typo3/cms-extbase": "^12.4 || ^13.4",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Seven\\TYPO3\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "seventypo3"
        }
    }
}
